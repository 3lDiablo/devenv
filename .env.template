DOCKER_REGISTRY=docker.io

# VMware has moved older images to the 'bitnamilegacy' repository.
KAFKA_IMAGE_REPOSITORY=bitnamilegacy/kafka
KAFKA_IMAGE_TAG=

POSTGRES_IMAGE_REPOSITORY=bitnamilegacy/postgresql
POSTGRES_IMAGE_TAG=
